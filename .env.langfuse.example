# Copy to .env.langfuse.local after creating a local Langfuse project.
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_SECRET_KEY=sk-lf-replace-me
# Must match the Environment filter in Langfuse (UI defaults to "default").
LANGFUSE_TRACING_ENVIRONMENT=default
